---
let year = new Date().getFullYear();
---

<footer class="border-t-2 border-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <p class="text-xs ibm-plex-mono-regular text-gray-400 uppercase tracking-widest">
      {year} — Jeo Carlo Lubao
    </p>
    <p class="text-xs ibm-plex-mono-regular text-gray-400 inline-flex items-center gap-2">
      Built with
      <img class="h-4 inline" alt="Astro" src="https://cdn.simpleicons.org/astro/fff" />
      <img class="h-4 inline" alt="Svelte" src="https://cdn.simpleicons.org/svelte/fff" />
      <img class="h-4 inline" alt="TypeScript" src="https://cdn.simpleicons.org/typescript/fff" />
    </p>
  </div>
</footer>
