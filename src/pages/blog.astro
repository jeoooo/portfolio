---
import Footer from "../components/astro-components/Footer.astro";
import Head from "../components/astro-components/Head.astro";
import Navbar from "../components/astro-components/Navbar.astro";
const allPosts = await Astro.glob('../blog/*.md');

function slugFromFile(file: string): string {
  return file.split('/').pop()?.replace('.md', '') ?? '';
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <Head />
  </head>
  <body class="bg-black">
    <Navbar />
    <main class="pt-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 border-t-2 border-white">
        <p class="text-xs uppercase tracking-[0.2em] text-gray-400 mb-2 ibm-plex-mono-regular">Writing</p>
        <h1 class="font-black font-syne mb-16 leading-none" style="font-size: clamp(2rem, 8vw, 3.75rem);">Blog</h1>

        <div class="divide-y divide-white">
          {allPosts.map((post) =>
            <a href={`/portfolio/blog/${slugFromFile(post.file)}`} class="group block py-10 hover:pl-4 transition-all duration-150">
              <p class="text-xs ibm-plex-mono-regular text-gray-400 mb-2">{post.frontmatter.date}</p>
              <h2 class="text-2xl sm:text-3xl font-black font-syne text-white group-hover:underline mb-3 leading-tight">
                {post.frontmatter.title}
              </h2>
              <p class="text-base ibm-plex-sans-regular text-gray-300 mb-4">
                {post.frontmatter.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {post.frontmatter.categories.map((category: string) => (
                  <span class="text-xs ibm-plex-mono-regular px-2 py-1 border border-white text-white">{category}</span>
                ))}
              </div>
            </a>
          )}
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
