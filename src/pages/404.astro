---
import Head from "../components/astro-components/Head.astro";
const image_404: string = "https://i.imgur.com/ElIMvxm.png";
---

<html lang="en">
  <head>
    <Head />
    <title>404 — Page Not Found</title>
  </head>
  <body>
    <main class="error-page">
      <div class="error-grid">
        <div class="error-rule"></div>
        <p class="error-label ibm-plex-mono-regular">ERROR / 404</p>
        <img src={image_404} alt="404" class="error-image" />
        <p class="error-headline syne-600">Page not found.</p>
        <p class="error-body ibm-plex-sans-light">
          The page you requested does not exist or has been moved.
        </p>
        <a href="/" class="error-link ibm-plex-sans-medium">
          &larr; Back to homepage
        </a>
      </div>
    </main>
  </body>
</html>

<style>
  body {
    background-color: #000;
    color: #fff;
    margin: 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .error-page {
    width: 100%;
    padding: var(--space-8) var(--space-6);
  }

  .error-grid {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .error-rule {
    width: 3rem;
    height: 3px;
    background-color: #fff;
    margin-bottom: var(--space-4);
  }

  .error-image {
    width: 10rem;
    height: auto;
    margin-bottom: var(--space-4);
  }

  .error-label {
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888;
    margin: 0;
  }

  .error-headline {
    font-size: var(--text-2xl);
    margin: 0;
    color: #fff;
  }

  .error-body {
    font-size: var(--text-base);
    color: #aaa;
    margin: 0;
    max-width: 36ch;
    line-height: var(--leading-relaxed);
  }

  .error-link {
    display: inline-block;
    margin-top: var(--space-4);
    padding: var(--space-2) var(--space-6);
    border: 1px solid #fff;
    color: #fff;
    text-decoration: none;
    font-size: var(--text-sm);
    letter-spacing: 0.05em;
    transition: background-color 0.15s, color 0.15s;
  }

  .error-link:hover {
    background-color: #fff;
    color: #000;
  }

</style>
