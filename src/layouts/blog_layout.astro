---
import Head from '../components/astro-components/Head.astro';
import Navbar from '../components/astro-components/Navbar.astro';
import Footer from '../components/astro-components/Footer.astro';

interface Props {
  frontmatter?: {
    title?: string;
    description?: string;
    date?: string;
    categories?: string[];
  };
}

const { frontmatter = {} } = Astro.props;
const { title, description, date, categories = [] } = frontmatter;
---
<html lang="en">
  <head>
    <Head />
    <style is:global>
      article h1, article h2, article h3, article h4 {
        font-family: var(--brand-font-display);
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        color: #fff;
      }
      article h1 { font-size: 2rem; }
      article h2 { font-size: 1.5rem; border-bottom: 1px solid #333; padding-bottom: 0.5rem; }
      article h3 { font-size: 1.25rem; }
      article p  { margin-bottom: 1rem; line-height: 1.75; color: #e5e5e5; }
      article a  { color: #fff; text-decoration: underline; }
      article ul, article ol { padding-left: 1.5rem; margin-bottom: 1rem; }
      article li { margin-bottom: 0.25rem; color: #e5e5e5; line-height: 1.75; }
      article pre  { background: #111; padding: 1rem; overflow-x: auto; margin-bottom: 1rem; border: 1px solid #333; border-radius: 0; }
      article code { font-family: var(--brand-font-mono); font-size: 0.85rem; color: #e5e5e5; }
      article pre code { color: #e5e5e5; }
      article blockquote { border-left: 3px solid #fff; padding-left: 1rem; color: #aaa; margin: 1.5rem 0; }
      article img { max-width: 100%; height: auto; margin: 1.5rem 0; }
    </style>
  </head>
  <body class="bg-black">
    <Navbar />
    <main class="pt-24 pb-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 border-t-2 border-white pt-16">

        <!-- Title -->
        {title && (
          <h1 class="font-syne font-black text-white leading-tight mb-6"
              style="font-size: clamp(2rem, 6vw, 4rem);">
            {title}
          </h1>
        )}

        <!-- Meta row -->
        <div class="flex flex-wrap items-center gap-4 mb-6">
          {date && (
            <span class="text-xs ibm-plex-mono-regular text-gray-400">{date}</span>
          )}
          {categories.map((cat: string) => (
            <span class="text-xs ibm-plex-mono-regular px-2 py-1 border border-white text-white">{cat}</span>
          ))}
        </div>

        {description && (
          <p class="text-lg ibm-plex-sans-regular text-gray-300 mb-10 max-w-2xl">{description}</p>
        )}

        <div class="border-t border-white/20 pt-10">
          <article>
            <slot />
          </article>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
